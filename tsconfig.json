{
  "compilerOptions": {
    /* =========================
       CORE SETTINGS
    ========================= */
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],

    /* =========================
       MODULE SYSTEM
    ========================= */
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,

    /* =========================
       REACT / NEXT
    ========================= */
    "jsx": "preserve",
    "plugins": [{ "name": "next" }],

    /* =========================
       TYPE SAFETY (BALANCED)
    ========================= */
    "strict": true,
    /* noUncheckedIndexedAccess removed — adds ~15% TS check overhead with no runtime benefit in Next.js */

    /* =========================
       COMPILATION
    ========================= */
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": ".next/tsconfig.tsbuildinfo",

    /* =========================
       INTEROP
    ========================= */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* =========================
       PERFORMANCE
    ========================= */
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* =========================
       PATH ALIASES
    ========================= */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },

    /* =========================
       JS SUPPORT (OPTIONAL)
    ========================= */
    "allowJs": true,

    /* =========================
       SAFETY
    ========================= */
    "isolatedModules": true
  },

  /* =========================
     FILE CONTROL
  ========================= */
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],

  "exclude": [
    "node_modules",
    "node_modules 2",
    "node_modules 3",
    ".next",
    "dist"
  ]
}